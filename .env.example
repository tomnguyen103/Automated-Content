# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional comma-separated hosts for `next dev` tunnel origins, for example: abc123.ngrok-free.dev
NEXT_ALLOWED_DEV_ORIGINS=

# Auth and billing
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=
# Optional hosted billing actions. When unset, billing controls stay disabled in local preview.
BILLING_UPGRADE_URL=
BILLING_CUSTOMER_PORTAL_URL=
# Only for secretless local previews and Playwright. Leave unset in production.
AUTH_LOCAL_PREVIEW=

# Database
DATABASE_URL=

# AI
AI_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=automated-content-agent

# Media
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# V2 background jobs and media workflows
# Trigger.dev local dev/deploy uses these keys. Preview branches also need TRIGGER_PREVIEW_BRANCH.
TRIGGER_PROJECT_REF=
TRIGGER_SECRET_KEY=
TRIGGER_PREVIEW_BRANCH=
TRIGGER_API_URL=
TRIGGER_VERSION=

# Raw video and render artifact storage. Use s3 by default; r2 is supported for non-Lambda rendering.
OBJECT_STORAGE_PROVIDER=s3
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_PUBLIC_BASE_URL=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_SIGNED_UPLOAD_MAX_BYTES=5368709120

# V2 media providers and protection
DEEPGRAM_API_KEY=
LUMA_API_KEY=
REMOTION_RENDERER_MODE=lambda
ARCJET_KEY=
ARCJET_MODE=detect
SENTRY_ENABLED=
SENTRY_DSN=

# Provider credentials
LINKEDIN_API_BASE_URL=https://api.linkedin.com
LINKEDIN_API_VERSION=202606
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_OAUTH_BASE_URL=https://www.linkedin.com/oauth/v2
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/connections/linkedin/callback
LINKEDIN_SCOPES="openid profile w_member_social"
X_API_BASE_URL=https://api.x.com
X_CLIENT_ID=
X_CLIENT_SECRET=
X_OAUTH_AUTHORIZE_URL=https://x.com/i/oauth2/authorize
X_REDIRECT_URI=http://localhost:3000/api/connections/x/callback
X_SCOPES="tweet.read tweet.write users.read offline.access"
# Required before storing live provider OAuth tokens.
# Generate with: openssl rand -base64 32
PROVIDER_TOKEN_ENCRYPTION_KEY=

# Queues and automation
REDIS_URL=
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
