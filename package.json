{
  "name": "automated-content-agent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "worker": "tsx workers/social-worker.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build:e2e": "node -e \"process.env.AUTH_LOCAL_PREVIEW='1'; process.env.PLAYWRIGHT_AUTH_LOCAL_PREVIEW='1'; process.env.NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=''; process.env.CLERK_SECRET_KEY=''; require('child_process').execSync('next build', { stdio: 'inherit', env: process.env })\"",
    "test:e2e": "npm run build:e2e && playwright test",
    "release:readiness": "tsx scripts/release-readiness.ts",
    "trigger:dev": "npx trigger.dev@latest dev",
    "trigger:deploy": "npx trigger.dev@latest deploy",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@clerk/nextjs": "^7.5.7",
    "@langchain/core": "^1.2.0",
    "@langchain/google": "^0.2.0",
    "@langchain/langgraph": "^1.4.4",
    "@langchain/openai": "^1.5.1",
    "@neondatabase/serverless": "1.1.0",
    "@trigger.dev/sdk": "^4.4.6",
    "bullmq": "^5.79.0",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "lucide-react": "1.21.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "overrides": {
    "postcss": "8.5.15",
    "esbuild": "0.28.1",
    "@opentelemetry/core": "2.8.0",
    "@opentelemetry/exporter-logs-otlp-http": "0.219.0",
    "@opentelemetry/exporter-metrics-otlp-http": "0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.219.0",
    "@opentelemetry/host-metrics": "0.39.0",
    "@opentelemetry/otlp-exporter-base": "0.219.0",
    "@opentelemetry/otlp-transformer": "0.219.0",
    "@opentelemetry/resources": "2.8.0",
    "@opentelemetry/sdk-logs": "0.219.0",
    "@opentelemetry/sdk-metrics": "2.8.0",
    "@opentelemetry/sdk-trace-base": "2.8.0",
    "@opentelemetry/sdk-trace-node": "2.8.0",
    "cookie": "0.7.2",
    "engine.io": "6.6.9",
    "engine.io-client": "6.6.6",
    "socket.io": "4.8.3",
    "socket.io-client": "4.8.3",
    "systeminformation": "5.31.11",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.3",
    "@playwright/test": "1.61.0",
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "dotenv": "17.4.2",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "4.3.1",
    "tsx": "^4.22.4",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
