# Production release env template
# Copy these keys into your production environment configuration.
# Store secret values in the production secret manager.
# Do not commit filled values. Blank, localhost, local, test, example, invalid,
# and wrong-scheme values are blocked by `npm run release:readiness`.

# App
NEXT_PUBLIC_APP_URL=

# Auth and billing
BILLING_CUSTOMER_PORTAL_URL=
BILLING_UPGRADE_URL=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Database
DATABASE_URL=

# AI and observability
AI_PROVIDER=openai
GEMINI_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
OPENAI_API_KEY=

# Media
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_URL_ENDPOINT=

# Provider credentials
LINKEDIN_API_BASE_URL=https://api.linkedin.com
LINKEDIN_API_VERSION=202606
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_OAUTH_BASE_URL=https://www.linkedin.com/oauth/v2
LINKEDIN_REDIRECT_URI=
LINKEDIN_SCOPES="openid profile w_member_social"
X_API_BASE_URL=https://api.x.com
X_CLIENT_ID=
X_CLIENT_SECRET=
X_OAUTH_AUTHORIZE_URL=https://x.com/i/oauth2/authorize
X_REDIRECT_URI=
X_SCOPES="tweet.read tweet.write users.read offline.access"

# Required before storing live provider OAuth tokens.
# Generate with: openssl rand -base64 32
PROVIDER_TOKEN_ENCRYPTION_KEY=

# Queues and automation
N8N_WEBHOOK_SECRET=
N8N_WEBHOOK_URL=
REDIS_URL=
